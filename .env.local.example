# ─────────────────────────────────────────────────────────────
#  Roast My GitHub — environment variables
#  Copy this file to ".env.local" and fill in what you have.
#  BOTH ARE OPTIONAL — the app runs with zero keys (Demo Mode).
# ─────────────────────────────────────────────────────────────

# Optional — enables real AI-generated roasts via Claude.
# Without it the app falls back to hand-written template roasts ("Demo Mode").
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — raises the GitHub API rate limit from 60 to 5,000 req/hr.
# Without it the app still works (60 unauthenticated requests/hr is plenty for trying it out).
# Create one at https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# Optional — override the Claude model. Leave blank to use the built-in default.
# Set this if the default model snapshot has been retired (the app otherwise
# falls back to template roasts on an invalid model).
ANTHROPIC_MODEL=
